rules_version = '2';

// Open read/write on the responsibility-center collections.
// Security model: a shared password (admin/viewer) gates the UI, plus URL
// secrecy of the deployed Netlify site. Firestore itself is intentionally
// open so the SPA can read/write without Firebase Auth.
//
// If you ever want to harden this, the upgrade path is:
//  1. Turn on Firebase Auth (Anonymous or Email).
//  2. Sign in anonymously after the password check in src/lib/auth.js.
//  3. Replace `if true;` below with `if request.auth != null;`.

service cloud.firestore {
  match /databases/{database}/documents {

    match /config/{doc} {
      allow read, write: if true;
    }
    match /tabs/{doc} {
      allow read, write: if true;
    }
    match /responsibilities/{doc} {
      allow read, write: if true;
    }
    match /tagCategories/{doc} {
      allow read, write: if true;
    }
    match /tags/{doc} {
      allow read, write: if true;
    }
    match /notes/{doc} {
      allow read, write: if true;
    }
    match /scheduleTasks/{doc} {
      allow read, write: if true;
    }
    match /taskInstances/{doc} {
      allow read, write: if true;
    }
    match /dailyPlans/{doc} {
      allow read, write: if true;
    }
    match /dailyUpdates/{doc} {
      allow read, write: if true;
    }
    match /chatMessages/{doc} {
      allow read, write: if true;
    }
  }
}
